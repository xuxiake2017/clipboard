# Local development SQLite path. Docker Compose overrides this with /app/data/clipboard.sqlite.
SQLITE_PATH=./data/clipboard.sqlite

# Optional deployment subpath. Example: /clipboard.
# This is a build-time Next.js basePath, so rebuild the app/image after changing it.
NEXT_PUBLIC_PUBLIC_PATH=

# Optional comma-separated client IP allowlist for creating new clipboards.
# Empty means anyone can create. Existing clipboards can still be joined with their password.
CLIPBOARD_CREATE_ALLOWED_IPS=

# Tencent COS. When these are absent, uploads fall back to public/uploads for local development.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_COS_BUCKET=example-1250000000
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_PUBLIC_URL=https://example-1250000000.cos.ap-guangzhou.myqcloud.com
